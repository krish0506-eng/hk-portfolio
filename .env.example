# Chat API - Ollama Configuration
# In production, set OLLAMA_URL to a reachable hosted Ollama endpoint.
OLLAMA_URL=https://your-ollama-host.example.com
OLLAMA_MODEL=gemma3:1b

# SMTP Configuration (for Contact form email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# Optional client API base (used for local testing only)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional EmailJS public config (only if you use EmailJS on client side)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Deployment URL (set during production deployment)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
